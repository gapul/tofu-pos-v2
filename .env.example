# Tofu POS — 環境変数テンプレート
#
# このファイルは git にコミットされる「テンプレート」です。
# 実際の値を入れた `.env` を作るときは、このファイルをコピーして使ってください:
#   cp .env.example .env
#
# `.env` は gitignored で、開発者ごとにローカルで管理します。
# 本番ビルドでは --dart-define で同じキーを上書きできます。

# Supabase project URL
# 例: https://yixdoktyhtrkcnghbjnh.supabase.co
SUPABASE_URL=

# Supabase anon (public) key
# Settings → API → "Project API keys" → anon public
SUPABASE_ANON_KEY=
