# EditorConfig is awesome: https://EditorConfig.org

root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space

[*.dart]
indent_size = 2
max_line_length = 80

[*.{yaml,yml}]
indent_size = 2

[*.{json,jsonc}]
indent_size = 2

[*.md]
indent_size = 2
trim_trailing_whitespace = false  # 行末2スペースで改行する記法を許可

[*.{kt,kts}]
indent_size = 4

[*.{swift,m,mm,h}]
indent_size = 4

[Makefile]
indent_style = tab

[*.sql]
indent_size = 2

[*.sh]
indent_size = 2
